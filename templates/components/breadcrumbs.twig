<nav class="breadcrumb is-small has-margin-bottom-none" aria-label="breadcrumbs">
    <ul>
        {% for item in _app.breadcrumbs %}
            <li {{ item.url is empty ? 'class="is-disabled"' }}>
                <a href="{{ item.url }}">{{ item.label }}</a>
            </li>
        {% endfor %}
    </ul>
</nav>