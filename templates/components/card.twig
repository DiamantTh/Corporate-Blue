{#
    {% embed "components/card.twig" with {
        'margin': 'large',
        'collapse': {
            'is_enabled': true,
            'cookie_name': 'applications',
        },
        'header': {
            'icon': 'fa-solid fa-tv',
            'title': applications,
        },
    } %}
        {% block content %}
            {% import "macros/macros.twig" as macros %}
            {% import "macros/forms.twig" as forms %}
        {% endblock %}

        {% block footer %}
            <div class="card-footer-item has-text-right">
                <a href="?page=admin_installed_packages">
                    {{ show_details }}
                </a>
