{% extends 'layout/intern.twig' %}


{% block page_scripts %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    <script>
        var records = {{ _records_json|raw }};
    </script>

	<script id="app-record-template" type="text/x-handlebars-template">
        <tr class="app-record-row">
            <td>
                {% verbatim %}
                {{# if is_dkim }}
                {% endverbatim %}
                    {{ forms.input({
                        'omit_id': true,
                        'name': 'host',
                        'is_required': true,
                        'addons': {
                            'right': {
                                'button': {
                                    'label': show,
                                    'type': 'button',
                                    'modal': 'app-modal-dkim'
                                }
                            }
                        },
                    }) }}
                {% verbatim %}
                {{else}}
                {% endverbatim %}
                    {{ forms.input({
                        'omit_id': true,
                        'name': 'host',
                        'is_required': true,
                    }) }}
                {% verbatim %}
                {{/ if }}
                {% endverbatim %}
            </td>
            <td>
                {{ forms.input({
                    'omit_id': true,
                    'name': 'ttl',
                    'type': 'number',
                    'min': 1,
                    'is_required': true,
                }) }}
            </td>
            <td>
                {{ forms.select({
                    'omit_id': true,
                    'name': 'type',
                    'options': _dns_record_types
                }) }}
            </td>
            <td>
                {% verbatim %}
                {{# if is_dkim }}
                {% endverbatim %}
                    {{ forms.input({
                        'omit_id': true,
                        'name': 'value',
                        'is_required': true,
                        'addons': {
                            'right': {
                                'button': {
                                    'label': show,
                                    'type': 'button',
                                    'modal': 'app-modal-dkim'
                                }
                            }
                        },
                    }) }}
                {% verbatim %}
                {{else}}
                {% endverbatim %}
                    {{ forms.input({
                        'omit_id': true,
                        'name': 'value',
                        'is_required': true,
                    }) }}
                {% verbatim %}
                {{/ if }}
                {% endverbatim %}
            </td>
            <td>
                {{ forms.button({
                    'label': remove,
                    'style': 'secondary',
                    'type': 'button',
                    'class': 'app-remove-record'
                }) }}
            </td>
        </tr>
	</script>

    <script src="/theme/bulma/assets/js/page_dns_editor_edit.js?{{ _globals.cache_control }}"></script>
{% endblock %}


{% block content %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    {# Intro #}
    <p class="has-margin-bottom-medium">
        {{ help|raw }}
    </p>

    <p class="has-margin-bottom-medium">
        <strong>{{ dns_settings_for_domain }}</strong><br>
        <a href="?page=domains&action=edit&id={{ _id }}">
            {{ _domain }}
        </a>

        {% if _is_modified %}
            {{ macros.tag(modified, 'is-info') }}
        {% endif %}

        {% if _is_disabled %}
            {{ macros.tag(disabled, 'is-danger') }}
        {% endif %}
    </p>

    <div class="has-margin-bottom-medium">
        <strong>DKIM</strong><br>
        {{ help_dkim|raw }}
        {% if not _dkim_record is empty %}
            <br>{{ help_dkim_external|format('<a class="has-text-link" data-open-modal="app-modal-dkim">' ~ show ~ '</a>')|raw }}<br>
        {% endif %}

        <div class="content">
            <ul class="list">
                <li class="list-item">{{ help_dkim_host|raw }}</li>
                <li class="list-item">{{ help_dkim_value|raw }}</li>
            </ul>
        </div>
    </div>

    {# Item table #}
    <form id="app-edit-dns-form" action="?page={{ _app.page }}&action=edit" method="post">
        <input type="hidden" name="update_zone" value="1">
        <input type="hidden" name="id" value="{{ _id }}">
        <input type="hidden" name="records" value="">
        {{ csrf_field() }}

        {{ forms.checkbox_wrapped({
            'label': disable_dns,
            'options': {
                'label': yes,
                'name': 'is_disabled',
                'value': '1',
                'is_checked': _is_disabled
            }
        }) }}

        <div class="has-margin-y-large"><!-- spacer --></div>

        <div class="card">
            <div class="card-content">

                <div class="app-show-with-dns-disabled" style="display: none">
                    <div class="has-text-centered has-text-grey">
                        {{ dns_is_disabled }}
                    </div>
                </div>

                <div class="app-show-with-dns-enabled" style="display: none">
                    <div class="table-container has-margin-bottom-small">
                        <table class="table is-fullwidth is-borderless">
                            <thead>
                                <tr>
                                    <th style="min-width: 225px;">
                                        {{ host }}
                                    </th>
                                    <th style="min-width: 125px; width: 125px">
                                        {{ ttl }}
                                    </th>
                                    <th class="is-narrow">
                                        {{ record_type }}
                                    </th>
                                    <th style="min-width: 225px; width: 60%">
                                        {{ value }}
                                    </th>
                                    <th class="is-narrow">
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="app-record-container">
                                <tr>
                                    <td>{{ _soa.host }}</td>
                                    <td>
                                        {{ forms.input({
                                            'name': 'soa_ttl',
                                            'value': _soa.ttl,
                                            'type': 'number',
                                            'min': 1
                                        }) }}

                                        {{ forms.button({
                                            'label': apply,
                                            'type': 'button',
                                            'icon': 'fa-solid fa-angles-down',
                                            'id': 'app-apply-ttl-to-all',
                                            'class': 'is-fullwidth'
                                        }) }}
                                    </td>
                                    <td>
                                        SOA
                                    </td>
                                    <td>
                                        {{ forms.input_wrapped({
                                            'help': primary_name_server,
                                            'name': 'soa_primary_name_server',
                                            'value': _soa.primary_name_server,
                                            'is_required': true
                                        }) }}
                                        {{ forms.input_wrapped({
                                            'help': email_of_responsible_person,
                                            'name': 'soa_rname',
                                            'value': _soa.rname,
                                            'is_required': true
                                        }) }}
                                        {{ forms.input_wrapped({
                                            'help': refresh,
                                            'name': 'soa_refresh',
                                            'value': _soa.refresh,
                                            'type': 'number',
                                            'min': 1,
                                            'is_required': true
                                        }) }}
                                        {{ forms.input_wrapped({
                                            'help': retry,
                                            'name': 'soa_retry',
                                            'value': _soa.retry,
                                            'type': 'number',
                                            'min': 1,
                                            'is_required': true
                                        }) }}
                                        {{ forms.input_wrapped({
                                            'help': expire,
                                            'name': 'soa_expire',
                                            'value': _soa.expire,
                                            'type': 'number',
                                            'min': 1,
                                            'is_required': true
                                        }) }}
                                        {{ forms.input_wrapped({
                                            'help': minimum,
                                            'name': 'soa_minimum',
                                            'value': _soa.minimum,
                                            'type': 'number',
                                            'min': 1,
                                            'is_required': true
                                        }) }}
                                    </td>
                                    <td></td>
                                </tr>

                                <!-- Content added by JavaScript -->

                                <tr id="app-add-records-before">
                                    <td colspan="42" class="has-text-centered has-padding-top-medium">
                                        {{ forms.button({
                                            'label': add_record,
                                            'type': 'button',
                                            'class': 'app-add-record'
                                        }) }}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>

        {% include 'components/call_to_action.twig' with {
            '_back': { 'label': back_to_search, 'target': 'dns_editor' },
            '_reset': _is_modified or _is_disabled,
            '_confirm': true
        } %}
    </form>

{#######################################################################################################################
    Modals
#######################################################################################################################}

    {# Reset #}
    {% embed "components/modal/modal.twig" with {
            '_id': 'app-modal-reset-settings',
            '_title': reset_settings,
            '_form': {
                'action': '?page=' ~ _app.page ~ '&action=edit',
                'hidden': {
                    'id': _id,
                    'reset_zone': true
                },
            },
            '_buttons': {
                'submit': { 'label': yes },
                'cancel': {},
            } } %}
        {% block body %}
            <p class="has-text-centered">
                {{ are_you_sure_reset_settings }}
            </p>
        {% endblock %}
    {% endembed %}

    {# Dkim #}
    {% include 'components/modal/dkim.twig' %}

{% endblock %}