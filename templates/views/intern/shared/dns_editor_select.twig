{% extends 'layout/intern.twig' %}


{% block page_scripts %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    <script>
        var domains = {{ _domains_json|raw }};
    </script>

    <script id="app-domain-template" type="text/x-handlebars-template">
        <tr>
            <td class="has-ws-no-wrap">
                <a href="?page=dns_editor&action=edit&id={% verbatim %}{{ id }}{% endverbatim %}">
                    {% include 'components/icon.twig' with {
                        '_type': 'edit',
                    } %}
                    {% verbatim %}{{ domain }}{% endverbatim %}
                </a>
            </td>
            <td class="is-narrow">
                {% verbatim %}
                {{# if is_modified}}
                    {% endverbatim %}{{ macros.tag(modified, 'is-info') }}{% verbatim %}
                {{/ if }}
                {{# if is_disabled}}
                    {% endverbatim %}{{ macros.tag(disabled, 'is-danger') }}{% verbatim %}
                {{/ if }}
                {% endverbatim %}
            </td>
        </tr>
	</script>

    <script src="/theme/bulma/assets/js/page_dns_editor_selection.js?{{ _globals.cache_control }}"></script>
{% endblock %}


{% block content %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    {# Intro #}
    <p class="has-margin-bottom-large">
        {{ help|raw }}
    </p>

    {% embed "components/card.twig" with {
        'header': {
            'icon': 'fa-solid fa-magnifying-glass',
            'title': domain_selection
        },
        'content': { 'is_centered': true }
    } %}
        {% block content %}
            {% import "macros/macros.twig" as macros %}
            {% import "macros/forms.twig" as forms %}

            {{ forms.input_wrapped({
                'label': search,
                'name': 'search',
                'type': 'search',
            }) }}

            <div class="has-margin-top-large"></div>

            {{ forms.label_wrapped({
                'label': domain_list,
                'help': domain_list_help
            }) }}

            {# No items #}
            <div id="app-no-items-available" style="display: none">
                <div class="has-text-centered has-text-grey">
                    - {{ no_items_available }} -
                </div>
            </div>

            {# Item table #}
            <div id="app-item-table" style="display: none">
                <div class="table-container">
                     <table class="table is-fullwidth is-striped is-hoverable">
                        <tbody id="app-domain-container">
                        </tbody>
                    </table>
                </div>
            </div>
        {% endblock %}
    {% endembed %}

{% endblock %}