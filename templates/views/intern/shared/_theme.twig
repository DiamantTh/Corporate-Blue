{% extends 'layout/intern.twig' %}


{% block page_scripts %}
<script>
    select2_prepareSelect('#input-my-unique-id', select2_formatUsers);
    select2_prepareSelect('#input-my-unique-id-2', select2_formatUsers, 0);
</script>

<script>
    $('#button_animation_success').on('click', function() {
        animateButton(this);
    });
    $('#button_animation_failure').on('click', function() {
        animateButton(this, false);
    });
</script>
{% endblock %}


