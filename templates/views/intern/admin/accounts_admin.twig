{% extends 'layout/intern.twig' %}


{% block content %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    {% include 'components/admin_accounts_tabs.twig' %}

    {% if _user.is_main_admin %}
        {# Button line #}
        {% include 'components/index_page_button_line.twig' with ({
            '_buttons': [
                forms.button({
                    'label': add_admin,
                    'style': 'primary',
                    'url': '?page=' ~ _app.page ~ '&action=add',
                })
            ],
            '_bulk_actions': {
                'delete': delete_selection
            },
            '_form_id': 'form-admin-account-index'
        }) %}
    {% endif %}

    {# Item table #}
    <div class="card">
        <div class="card-content">
            {% if _admin_accounts is empty %}
                <div class="has-text-centered has-text-grey">
                    - {{ no_items_available }} -
                </div>
            {% else %}
                {% include 'components/table_scroll_container.twig' %}
                <form id="form-admin-account-index" action="?page=admin_accounts_admin" method="post">
                    {{ csrf_field() }}

                    <div class="table-container">
                        <table class="table is-fullwidth is-striped is-hoverable has-valigned-cells">
                            <thead>
                                <tr>
                                    {% if _user.is_main_admin %}
                                        {{ macros.header_checkbox() }}
                                    {% endif %}
                                    <th {{ macros.header_sorting('username') }}>
                                        {{ username }}
                                    </th>
                                    <th {{ macros.header_sorting('is_main_admin') }}>
                                        {{ main_administrator }}
                                    </th>
                                    <th {{ macros.header_sorting('last_login_sort') }}>
                                        {{ last_login }}
                                    </th>
                                    {% if _user.is_main_admin %}
                                        <th class="is-narrow">
                                            {{ actions }}
                                        </th>
                                    {% endif %}
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in _admin_accounts %}
                                    <tr>
                                        {% if _user.is_main_admin %}
                                            {{ item.can_be_modified ? macros.row_checkbox(item.id) : '<td></td>' }}
                                        {% endif %}
                                        <td class="has-ws-no-wrap">
                                            {{ item.username }}
                                        </td>
                                        <td>
                                            {{ macros.status_icon(item.is_main_admin, [yes, no], true) }}
                                        </td>
                                        <td class="is-narrow">
                                            {{ item.last_login|default('—') }}
                                        </td>
                                        {% if _user.is_main_admin %}
                                            <td class="is-narrow">
                                                {% if item.can_be_modified %}
                                                    {% include 'components/icon.twig' with {
                                                        '_type': 'edit',
                                                        '_url': '?page=admin_accounts_admin&action=edit&id=' ~ item.id
                                                    } %}

                                                    {% include 'components/icon.twig' with {
                                                        '_type': 'delete',
                                                        '_url': '?page=admin_accounts_admin&action=delete&id=' ~ item.id
                                                    } %}
                                                {% endif %}
                                            </td>
                                        {% endif %}
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="42">
                                        {{ _admin_accounts|length|i18n_format }} {{ items_total }}
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>

{% endblock %}