{% extends 'layout/intern.twig' %}


{% block content %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    {% include 'components/admin_accounts_tabs.twig' %}

    {# Intro #}
    <p class="has-margin-bottom-large">
        {{ client_groups_help|raw }}
    </p>


    {% if _user.is_main_admin %}
        {# Button line #}
        {% include 'components/index_page_button_line.twig' with ({
            '_buttons': [
                forms.button({
                    'label': add_client_group,
                    'style': 'primary',
                    'url': '?page=' ~ _app.page ~ '&action=add',
                })
            ],
            '_bulk_actions': {
                'delete': delete_selection
            },
            '_form_id': 'form-client-group-index'
        }) %}
    {% endif %}

    {# Item table #}
    <div class="card">
        <div class="card-content">
            {% if _client_groups is empty %}
                <div class="has-text-centered has-text-grey">
                    - {{ no_items_available }} -
                </div>
            {% else %}
                {% include 'components/table_scroll_container.twig' %}
                <form id="form-client-group-index" action="?page={{ _app.page }}" method="post">
                    {{ csrf_field() }}

                    <div class="table-container">
                        <table class="table is-fullwidth is-striped is-hoverable has-valigned-cells">
                            <thead>
                                <tr>
                                    {{ macros.header_checkbox() }}

                                    <th {{ macros.header_sorting('name') }}>
                                        {{ name }}
                                    </th>
                                    <th {{ macros.header_sorting('members_sorting') }}>
                                        {{ members }}
                                    </th>
                                    <th class="is-narrow">
                                        {{ actions }}
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in _client_groups %}
                                    <tr>
                                        {{ macros.row_checkbox(item.id) }}

                                        <td class="has-ws-no-wrap">
                                            {{ item.name }}
                                        </td>
                                        <td>
                                            <ul>
                                                {% for member in item.members %}
                                                    <li>{{ macros.link_to_switch_to_client(member.id, member.username, _app.page) }}</li>
                                                {% endfor %}
                                            <ul>
                                        </td>
                                        <td class="is-narrow">
                                            {% include 'components/icon.twig' with {
                                                '_type': 'edit',
                                                '_url': '?page=' ~ _app.page ~ '&action=edit&id=' ~ item.id
                                            } %}

                                            {% include 'components/icon.twig' with {
                                                '_type': 'delete',
                                                '_url': '?page=' ~ _app.page ~ '&action=delete&id=' ~ item.id
                                            } %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="42">
                                        {{ _client_groups|length|i18n_format }} {{ items_total }}
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>

{% endblock %}