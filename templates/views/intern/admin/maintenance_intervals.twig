{% extends 'layout/intern.twig' %}


{% block page_scripts %}
    <script src="/theme/bulma/assets/js/page_maintenance_intervals.js?{{ _globals.cache_control }}"></script>
{% endblock %}


{% block content %}
    {% import "macros/macros.twig" as macros %}
    {% import "macros/forms.twig" as forms %}

    {# Intro #}
    <p class="has-margin-bottom-large">
        {{ help|raw }}
    </p>

    {# Item table #}
    <div class="card">
        <div class="card-content">
            {% include 'components/table_scroll_container.twig' %}
            <div class="table-container">
                <table class="table is-fullwidth is-striped is-hoverable has-valigned-cells">
                    <thead>
                        <tr>
                            <th>
                                {{ task_name }}
                            </th>
                            <th>
                                {{ is_enabled }}
                            </th>
                            <th>
                                {{ last_run }}
                            </th>
                            <th>
                                {{ interval }}
                            </th>
                            <th>
                                {{ timeframe }}
                            </th>
                            <th class="is-narrow">
                                {{ actions }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in _tasks %}
                            <tr>
                                <td style="display: none">
                                    <input type="text" name="id" value="{{ item.id }}">
                                    <input type="text" name="name" value="{{ item.name }}">
                                    <input type="text" name="is_enabled" value="{{ item.is_enabled }}">
                                    <input type="text" name="interval" value="{{ item.interval }}">
                                    <input type="text" name="interval_unit" value="{{ item.interval_unit }}">
                                    <input type="text" name="interval_disable_minutes" value="{{ item.interval_disable_minutes }}">
                                    <input type="text" name="timeframe_start" value="{{ item.timeframe_start }}">
                                    <input type="text" name="timeframe_end" value="{{ item.timeframe_end }}">
                                </td>
                                <td>
                                    <strong>
                                        {{ item.name }}
                                    </strong>
                                    {% if item.is_started %}
                                        {{ macros.tag(will_be_started, 'is-info') }}
                                    {% endif %}
                                    <br>
                                    {{ item.help|raw }}
                                </td>
                                <td class="has-ws-no-wrap">
                                    {{ macros.status_icon(item.is_enabled, [enabled, disabled]) }}
                                </td>
                                <td class="has-ws-no-wrap">
                                    {{ item.last_run|default('—') }}
                                </td>
                                <td class="has-ws-no-wrap">
                                    <strong>
                                        {{ item.interval_string }}
                                    </strong>
                                </td>
                                <td class="has-ws-no-wrap">
                                    {{ item.timeframe_string|raw }}
                                </td>
                                <td class="is-narrow">
                                    <span class="app-edit-task">
                                        {% include 'components/icon.twig' with {
                                            '_type': 'edit',
                                            '_url': 'javascript:void(0)'
                                        } %}
                                    </span>

                                    {% include 'components/icon.twig' with {
                                        '_type': 'start',
                                        '_url': '?page=' ~ _app.page ~ '&start_task=' ~ item.id,
                                        '_tooltip': tooltip_start_now
                                    } %}

                                    {% if item.logfile %}
                                        {% include 'components/icon.twig' with {
                                            '_type': 'logs',
                                            '_url': '?page=admin_logs&logfile='~item.logfile,
                                            '_is_new_tab': true,
                                        } %}
                                    {% else %}
                                        {% include 'components/icon.twig' with { '_type': 'spacer' } %}
                                    {% endif %}

                                    {% if item.additional_config %}
                                        {% include 'components/icon.twig' with {
                                            '_type': 'configure',
                                            '_url': item.additional_config,
                                            '_is_new_tab': true,
                                        } %}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="42">
                                {{ _tasks|length|i18n_format }} {{ items_total }}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

{#######################################################################################################################
    Modals
#######################################################################################################################}

    {% embed "components/modal/modal.twig" with {
            '_id': 'app-modal-edit-task',
            '_title': edit_settings,
            '_form': {
                'action': '?page=' ~ _app.page,
                'hidden': {
                    'submit': true,
                    'id': ''
                },
            },
            '_buttons': {
                'submit': {},
                'cancel': {},
            } } %}
        {% block body %}
            {% import "macros/forms.twig" as forms %}

            <div id="app-task-name">
                {{ forms.label_wrapped({
                    'label': task_name,
                    'value': '...'
                }) }}
            </div>

            {{ forms.checkbox_wrapped({
                'label': is_enabled,
                'options': {
                    'label': yes,
                    'name': 'is_enabled',
                    'value': '1',
                }
            }) }}

            {{ forms.input_wrapped({
                'label': interval,
                'name': 'interval',
                'type': 'number',
                'min': 0,
                'addons': {
                    'left': {
                        'type': 'select',
                        'select': {
                            'name': 'interval_unit',
                            'options': _interval_units,
                        }
                    },
                }
            }) }}

            {{ forms.label_wrapped({
                'label': timeframe,
            }) }}

            <div class="columns">
                <div class="column">
                    {{ forms.select_wrapped({
                        'help': execution_timeframe_start,
                        'name': 'timeframe_start',
                        'options': _hours
                    }) }}
                </div>
                <div class="column">
                    {{ forms.select_wrapped({
                        'help': execution_timeframe_end,
                        'name': 'timeframe_end',
                        'options': _hours
                    }) }}
                </div>
            </div>
        {% endblock %}
    {% endembed %}

{% endblock %}