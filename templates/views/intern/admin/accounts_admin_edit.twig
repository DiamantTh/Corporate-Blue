{% extends 'layout/intern.twig' %}


{% block content %}

    {% embed "components/card.twig" with { 'content': { 'is_centered': true } } %}
        {% block content %}
            {% import "macros/macros.twig" as macros %}
            {% import "macros/forms.twig" as forms %}

            <form action="?page={{ _app.page }}&action={{ _action }}" method="post" autocomplete="off">
                <input type="hidden" name="submit" value="1">
                <input type="hidden" name="id" value="{{ _id }}">
                {{ csrf_field() }}

                {{ forms.input_wrapped({
                    'label': username,
                    'name': 'username',
                    'type': 'text',
                    'is_required': true,
                    'value': _username,
                }) }}

                {% include 'components/form_password.twig' with { '_leave_empty': _action == 'edit' } %}

                {{ forms.input_wrapped({
                    'label': email_address,
                    'name': 'email',
                    'type': 'email',
                    'is_required': true,
                    'value': _email,
                }) }}

                {{ forms.select_wrapped({
                    'label': language,
                    'name': 'language',
                    'options': _languages,
                    'selected': _languages_selected,
                }) }}

                {{ forms.checkbox_wrapped({
                    'label': main_administrator,
                    'help': main_administrator_help,
                    'options': {
                        'label': yes,
                        'name': 'is_main_admin',
                        'value': '1',
                        'is_checked': _is_main_admin
                    }
                }) }}

                {% include 'components/call_to_action.twig' with { '_back': { 'target': 'admin_accounts_admin' }, '_confirm': true } %}
            </form>
        {% endblock %}
    {% endembed %}
 
{% endblock %}