<!DOCTYPE html>
<html lang="{{ _app.language }}" dir="{{ _app.text_direction }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {# Stop microsoft edge to style numbers, which it assumes are telephone numbers #}
    <meta name="format-detection" content="telephone=no">

    {% if _white_label.favicon_url %}
        <link type="image/x-icon" rel="shortcut icon" href="{{ _white_label.favicon_url }}&{{ _globals.cache_control }}">
    {% else %}
        <link rel="apple-touch-icon" sizes="180x180" href="/theme/bulma/assets/img/favicon/apple-touch-icon.png?v=ngk7O7gqB9">
        <link rel="icon" type="image/png" sizes="32x32" href="/theme/bulma/assets/img/favicon/favicon-32x32.png?v=ngk7O7gqB9">
        <link rel="icon" type="image/png" sizes="16x16" href="/theme/bulma/assets/img/favicon/favicon-16x16.png?v=ngk7O7gqB9">
        <link rel="manifest" href="/theme/bulma/assets/img/favicon/site.webmanifest?v=ngk7O7gqB9">
        <link rel="mask-icon" href="/theme/bulma/assets/img/favicon/safari-pinned-tab.svg?v=ngk7O7gqB9" color="#2b5797">
        <link rel="shortcut icon" href="/theme/bulma/assets/img/favicon/favicon.ico?v=ngk7O7gqB9">
        <meta name="apple-mobile-web-app-title" content="KeyHelp">
        <meta name="application-name" content="KeyHelp">
        <meta name="msapplication-TileColor" content="#2b5797">
        <meta name="msapplication-config" content="/theme/bulma/assets/img/favicon/browserconfig.xml?v=ngk7O7gqB9">
        <meta name="theme-color" content="#ffffff">
    {% endif %}

    <title>{{ _app.page_title }}</title>
    <link rel="stylesheet" href="/theme/bulma/assets/css/style{{ _app.theme.is_dark_mode ? '-dark' }}{{ _app.text_direction == 'rtl' ? '-rtl' }}.css?{{ _globals.cache_control }}">

    {# ─── Tailwind (prefix: tw-, no preflight to keep Bulma intact) ─── #}
    <script src="/theme/bulma/assets/vendor/tailwind/tailwind.min.js"></script>
    <script>
        tailwind.config = {
            prefix: 'tw-',
            corePlugins: { preflight: false },
            theme: {
                extend: {
                    colors: {
                        'corp': {
                            '500': '#3273DC',
                            '700': '#0f3d6e',
                            '800': '#00305D',
                            '900': '#00182e'
                        }
                    }
                }
            }
        };
    </script>

    {# ─── Corporate Blue Overrides ─────────────────────────────────────── #}
    <style>
        /* ── Base & layout ─────────────────────────────────────────────── */
        html, body { background-color: #07111d !important; color: rgba(192,216,240,.9) !important; }
        #content-wrapper { background-color: #091624 !important; }
        #content { color: rgba(192,216,240,.9) !important; }
        #footer { color: rgba(192,216,240,.5) !important; border-top: 1px solid #1e3a5a; }
        #footer a { color: rgba(192,216,240,.6) !important; }

        /* ── Sidebar ────────────────────────────────────────────────────── */
        #sidebar { background: #0a1928 !important; }
        #sidebar .menu-label { color: rgba(192,216,240,.55) !important; }
        #sidebar .menu-list a { color: rgba(192,216,240,.85) !important; }
        #sidebar .menu-list a:hover,
        #sidebar .menu-list a.is-active { background: rgba(255,255,255,.10) !important; color: #fff !important; }
        #sidebar .menu-list a small .icon { color: rgba(192,216,240,.4) !important; }

        /* ── Header ─────────────────────────────────────────────────────── */
        #header { background: #0e1e30 !important; border-bottom: 1px solid #2c4060 !important; }
        #header .has-text-grey { color: rgba(192,216,240,.6) !important; }
        #header #clock { color: rgba(192,216,240,.75) !important; }

        /* ── User menu / dropdowns ───────────────────────────────────────── */
        #user-menu,
        .dropdown-content { background-color: #112640 !important; border: 1px solid #1e3a5a !important; box-shadow: 0 4px 16px rgba(0,0,0,.5) !important; }
        .dropdown-item, .dropdown-item a { color: rgba(192,216,240,.85) !important; }
        .dropdown-item:hover, .dropdown-item:focus { background-color: rgba(50,115,220,.15) !important; color: #fff !important; }
        .dropdown-divider { background-color: #1e3a5a !important; }

        /* ── Cards ───────────────────────────────────────────────────────── */
        .card { background-color: #0e1e30 !important; border-radius: 8px !important; box-shadow: 0 2px 8px rgba(0,0,0,.4) !important; color: rgba(192,216,240,.9) !important; }
        .card-header { background-color: #112640 !important; border-radius: 8px 8px 0 0 !important; border-bottom: 1px solid #2c4060 !important; }
        .card-header-title, .card-header .title { color: rgba(192,216,240,.95) !important; }
        .card-content { color: rgba(192,216,240,.85) !important; }
        .card-footer { background-color: #0e1e30 !important; border-top: 1px solid #1e3a5a !important; }
        .card-footer-item { color: rgba(192,216,240,.7) !important; border-right: 1px solid #1e3a5a !important; }

        /* ── Box ─────────────────────────────────────────────────────────── */
        .box { background-color: #0e1e30 !important; color: rgba(192,216,240,.9) !important; box-shadow: 0 2px 12px rgba(0,0,0,.5) !important; }

        /* ── Titles & text ───────────────────────────────────────────────── */
        .title, .subtitle { color: rgba(192,216,240,.95) !important; }
        .content-title .title { color: #c0d8f0 !important; }
        .label { color: rgba(192,216,240,.85) !important; }
        .help { color: rgba(192,216,240,.55) !important; }
        strong, b { color: rgba(192,216,240,.95) !important; }
        .has-text-grey, .has-text-grey-dark { color: rgba(192,216,240,.55) !important; }
        .has-text-grey-light { color: rgba(192,216,240,.4) !important; }
        a { color: #5a9fdc !important; }
        a:hover { color: #82baf0 !important; }

        /* ── Breadcrumbs ─────────────────────────────────────────────────── */
        .breadcrumb li a { color: rgba(192,216,240,.65) !important; }
        .breadcrumb li.is-active a { color: rgba(192,216,240,.95) !important; }
        .breadcrumb li + li::before { color: rgba(192,216,240,.35) !important; }

        /* ── Tables ──────────────────────────────────────────────────────── */
        .table { background-color: transparent !important; color: rgba(192,216,240,.9) !important; }
        .table td, .table th { border-color: #1e3a5a !important; color: rgba(192,216,240,.85) !important; }
        .table thead th { color: rgba(192,216,240,.95) !important; border-bottom-color: #2c4060 !important; }
        .table tfoot td, .table tfoot th { border-top-color: #2c4060 !important; }
        .table tbody tr:hover td { background-color: rgba(50,115,220,.08) !important; }
        .table.is-striped tbody tr:not(.is-selected):nth-child(even) { background-color: rgba(14,30,48,.6) !important; }
        .table.is-hoverable tbody tr:not(.is-selected):hover { background-color: rgba(50,115,220,.10) !important; }

        /* ── Forms: input, textarea, select ─────────────────────────────── */
        .input, .textarea, .select select {
            background-color: #0c1a2b !important;
            border-color: #2c4060 !important;
            color: rgba(192,216,240,.9) !important;
        }
        .input::placeholder, .textarea::placeholder { color: rgba(192,216,240,.35) !important; }
        .input:focus, .textarea:focus, .select select:focus {
            border-color: #3273DC !important;
            box-shadow: 0 0 0 0.125em rgba(50,115,220,.25) !important;
        }
        .input[disabled], .textarea[disabled], .select select[disabled] {
            background-color: #07111d !important;
            border-color: #1e3a5a !important;
            color: rgba(192,216,240,.4) !important;
        }
        .select:not(.is-multiple):not(.is-loading)::after { border-color: rgba(192,216,240,.6) !important; }
        .control.has-icons-left .icon, .control.has-icons-right .icon { color: rgba(192,216,240,.5) !important; }
        .checkbox, .radio { color: rgba(192,216,240,.85) !important; }

        /* ── Buttons ─────────────────────────────────────────────────────── */
        .button:not(:is(.is-primary, .is-link, .is-info, .is-success, .is-warning, .is-danger)) {
            background-color: #112640 !important;
            border-color: #2c4060 !important;
            color: rgba(192,216,240,.9) !important;
        }
        .button:not(:is(.is-primary, .is-link, .is-info, .is-success, .is-warning, .is-danger)):hover {
            background-color: #1a3558 !important;
            border-color: #3273DC !important;
            color: #fff !important;
        }

        /* ── Notifications ───────────────────────────────────────────────── */
        .notification:not([class*="is-"]) { background-color: #0e1e30 !important; color: rgba(192,216,240,.85) !important; }

        /* ── Tabs ────────────────────────────────────────────────────────── */
        .tabs a { border-bottom-color: #2c4060 !important; color: rgba(192,216,240,.7) !important; }
        .tabs a:hover { border-bottom-color: #3273DC !important; color: rgba(192,216,240,.95) !important; }
        .tabs li.is-active a { border-bottom-color: #3273DC !important; color: #3273DC !important; }
        .tabs.is-boxed a, .tabs.is-toggle a { background-color: transparent !important; border-color: #2c4060 !important; color: rgba(192,216,240,.7) !important; }
        .tabs.is-boxed li.is-active a, .tabs.is-toggle li.is-active a { background-color: #3273DC !important; border-color: #3273DC !important; color: #fff !important; }
        .tabs ul { border-bottom-color: #2c4060 !important; }

        /* ── Panel ───────────────────────────────────────────────────────── */
        .panel-heading { background-color: #112640 !important; color: rgba(192,216,240,.95) !important; }
        .panel-block { background-color: #0e1e30 !important; border-color: #1e3a5a !important; color: rgba(192,216,240,.85) !important; }
        .panel-block:hover { background-color: rgba(50,115,220,.1) !important; }
        .panel-tabs a { color: rgba(192,216,240,.65) !important; border-bottom-color: #2c4060 !important; }
        .panel-tabs a.is-active { border-bottom-color: #3273DC !important; color: #3273DC !important; }

        /* ── Modal ───────────────────────────────────────────────────────── */
        .modal-card-head, .modal-card-foot { background-color: #112640 !important; border-color: #2c4060 !important; }
        .modal-card-title { color: rgba(192,216,240,.95) !important; }
        .modal-card-body { background-color: #0e1e30 !important; color: rgba(192,216,240,.85) !important; }
        .modal-background { background-color: rgba(0,0,0,.75) !important; }

        /* ── Messages / notifications colored ───────────────────────────── */
        .message { background-color: #0e1e30 !important; }
        .message-header { background-color: #112640 !important; color: rgba(192,216,240,.95) !important; }
        .message-body { border-color: #2c4060 !important; color: rgba(192,216,240,.85) !important; }

        /* ── Tags ────────────────────────────────────────────────────────── */
        .tag:not([class*="is-"]) { background-color: #152b47 !important; color: rgba(192,216,240,.85) !important; }

        /* ── Navbar (inside content) ─────────────────────────────────────── */
        .navbar { background-color: #0e1e30 !important; }
        .navbar-item, .navbar-link { color: rgba(192,216,240,.85) !important; }
        .navbar-dropdown { background-color: #112640 !important; border-top-color: #3273DC !important; }

        /* ── Progress bars ───────────────────────────────────────────────── */
        progress[data-load-level="low"]    { background-color: #1a3060 !important; }
        progress[data-load-level="low"]::-webkit-progress-value    { background-color: #3273DC !important; }
        progress[data-load-level="medium"] { background-color: #2a2010 !important; }
        progress[data-load-level="medium"]::-webkit-progress-value { background-color: #FFAA00 !important; }
        progress[data-load-level="high"]   { background-color: #2a1010 !important; }
        progress[data-load-level="high"]::-webkit-progress-value   { background-color: #FF2B56 !important; }

        /* ── Misc ────────────────────────────────────────────────────────── */
        hr { background-color: #1e3a5a !important; }
        .is-divider { border-top-color: #1e3a5a !important; }
        .is-divider[data-content]::after { background-color: #091624 !important; color: rgba(192,216,240,.5) !important; }
        code, pre { background-color: #07111d !important; color: #82baf0 !important; }
        pre code { background-color: transparent !important; }
    </style>

    {% block page_css %}{% endblock %}

    {% if _white_label.css %}
        <style>
            {{ _white_label.css|raw }}
        </style>
    {% endif %}
</head>
<body class="default-mode">
    {% block body_content %}{% endblock %}

    <script>
        var hash = {{ js_hash|raw }};
        Object.freeze(hash);
    </script>
    <script src="/theme/bulma/assets/vendor/jquery/jquery.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/perfect-scrollbar/perfect-scrollbar.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/echarts/echarts.min.js"></script>
    <script src="/theme/bulma/assets/vendor/handlebars/handlebars.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/tippy/popper.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/tippy/tippy.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/select2/select2.min.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/vendor/select2/i18n/{{ _app.language }}.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/js/functions.js?{{ _globals.cache_control }}"></script>
    <script src="/theme/bulma/assets/js/main.js?{{ _globals.cache_control }}"></script>

    {% block page_scripts %}{% endblock %}

    {% if _white_label.javascript %}
        <script type="text/javascript">
            {{ _white_label.javascript|raw }}
        </script>
    {% endif %}
</body>
</html>